{
  "name": "srzeditor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "tsc -b && vite build && electron-builder",
    "electron:build:win": "tsc -b && vite build && electron-builder --win",
    "electron:build:mac": "tsc -b && vite build && electron-builder --mac"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.3.2",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^1.1.0"
  },
  "build": {
    "appId": "com.srzeditor.app",
    "productName": "SRZ Editor",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "dist-electron/**/*"],
    "asarUnpack": ["**/node_modules/ffmpeg-static/**/*"],
    "win": { "target": [{ "target": "nsis", "arch": ["x64"] }] },
    "mac": { "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }] }
  }
}
